# Copy to backend/.env — never commit the real file

# Your private Discord webhook (server-side ONLY)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Required — clients authenticate with this (generate: python -c "import secrets; print('aller_'+secrets.token_urlsafe(32))")
TELEMETRY_API_KEY=aller_CHANGE_ME

TELEMETRY_BRAND=Alleral Ops
TELEMETRY_HOST=0.0.0.0
TELEMETRY_PORT=8787

# Optional scale tuning
TELEMETRY_MAX_QUEUE=5000
TELEMETRY_IP_RATE_PER_MIN=120
TELEMETRY_HEARTBEAT_BATCH_SEC=90
TELEMETRY_DISCORD_INTERVAL_SEC=0.55
