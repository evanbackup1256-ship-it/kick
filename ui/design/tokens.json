{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "Alleral UI V2",
    "version": "2.0.0-alleral-v2",
    "source": "ui/windui/arrrel.luau + ui/windui/v2/boost.luau",
    "references": [
      "https://brady-xyz.gitbook.io/maclib-ui-library",
      "https://github.com/Fraktality/spr"
    ]
  },
  "color": {
    "accent": { "hex": "#53fc18", "figma": "color/accent/primary" },
    "accentSoft": { "hex": "#8dff52", "figma": "color/accent/soft" },
    "accentHot": { "hex": "#2dff62", "figma": "color/accent/hot" },
    "canvas": { "hex": "#070708", "figma": "color/bg/canvas" },
    "surface": { "hex": "#0e0e11", "figma": "color/bg/surface" },
    "card": { "hex": "#131318", "figma": "color/bg/card" },
    "cardHover": { "hex": "#1a1a22", "figma": "color/bg/card-hover" },
    "text": { "hex": "#f4f4f8", "figma": "color/text/primary" },
    "muted": { "hex": "#9ca3af", "figma": "color/text/muted" },
    "divider": { "hex": "#ffffff", "figma": "color/border/divider", "opacity": 0.1 },
    "trackOff": { "hex": "#24242e", "figma": "color/control/track-off" },
    "trackOn": { "hex": "#163512", "figma": "color/control/track-on" },
    "knob": { "hex": "#fafafc", "figma": "color/control/knob" },
    "glow": { "hex": "#53fc18", "figma": "color/effect/glow" },
    "notifyWarn": { "hex": "#ffd166", "figma": "color/semantic/warn" },
    "notifyError": { "hex": "#ff5c5c", "figma": "color/semantic/error" },
    "synth": { "hex": "#ff2fd6", "figma": "color/theme/synth" },
    "ocean": { "hex": "#22d3ee", "figma": "color/theme/ocean" },
    "ember": { "hex": "#fb7185", "figma": "color/theme/ember" }
  },
  "layout": {
    "corner": { "px": 12, "figma": "radius/window" },
    "windowPad": { "px": 24, "figma": "spacing/window/padding" },
    "sidebarWidth": { "px": 280, "figma": "size/sidebar/width" },
    "elementGap": { "px": 16, "figma": "spacing/element/gap" },
    "sectionGap": { "px": 15, "figma": "spacing/section/gap" },
    "sectionInner": { "px": 10, "figma": "spacing/section/inner" },
    "sectionPadTop": { "px": 22, "figma": "spacing/section/pad-top" },
    "sectionPadBottom": { "px": 20, "figma": "spacing/section/pad-bottom" },
    "sectionPadLeft": { "px": 20, "figma": "spacing/section/pad-left" },
    "sectionPadRight": { "px": 18, "figma": "spacing/section/pad-right" },
    "contentPadX": { "px": 20, "figma": "spacing/content/x" },
    "scrollPadTop": { "px": 10, "figma": "spacing/scroll/top" },
    "scrollPadBottom": { "px": 15, "figma": "spacing/scroll/bottom" },
    "scrollPadLeft": { "px": 11, "figma": "spacing/scroll/left" },
    "scrollPadRight": { "px": 3, "figma": "spacing/scroll/right" },
    "sidebarPadTop": { "px": 31, "figma": "spacing/sidebar/top" },
    "sidebarPadX": { "px": 10, "figma": "spacing/sidebar/x" },
    "tabHeight": { "px": 40, "figma": "size/tab/height" },
    "tabPadLeft": { "px": 24, "figma": "spacing/tab/left" },
    "tabPadRight": { "px": 12, "figma": "spacing/tab/right" },
    "tabGroupGap": { "px": 17, "figma": "spacing/tab/group-gap" },
    "rowHeight": { "px": 38, "figma": "size/row/height" },
    "topbarHeight": { "px": 68, "figma": "size/topbar/height" },
    "notifyCorner": { "px": 10, "figma": "radius/notification" },
    "glowSpread": { "px": 18, "figma": "effect/glow/spread" }
  },
  "opacity": {
    "divider": { "value": 0.9, "figma": "opacity/divider" },
    "sectionFill": { "value": 0.98, "figma": "opacity/section/fill" },
    "sectionStroke": { "value": 0.95, "figma": "opacity/section/stroke" },
    "windowStroke": { "value": 0.9, "figma": "opacity/window/stroke" },
    "rowLabel": { "value": 0.5, "figma": "opacity/row/label" },
    "tabInactiveText": { "value": 0.42, "figma": "opacity/tab/text-inactive" },
    "tabInactiveIcon": { "value": 0.45, "figma": "opacity/tab/icon-inactive" },
    "tabActiveFill": { "value": 0.9, "figma": "opacity/tab/active-fill" },
    "glassVeil": { "value": 0.06, "figma": "opacity/glass/veil" },
    "ambientGlow": { "value": 0.08, "figma": "opacity/effect/ambient" }
  },
  "motion": {
    "snappy": { "frequency": 7.5, "damping": 1 },
    "soft": { "frequency": 4.8, "damping": 1.12 },
    "bouncy": { "frequency": 5.8, "damping": 0.72 },
    "pop": { "frequency": 6.4, "damping": 0.82 },
    "micro": { "frequency": 9.5, "damping": 1 },
    "open": { "frequency": 5.6, "damping": 0.88 },
    "close": { "frequency": 7.2, "damping": 1.05 },
    "notify": { "frequency": 6.2, "damping": 0.9 },
    "toggle": { "frequency": 7.2, "damping": 0.78 },
    "tab": { "frequency": 6, "damping": 0.85 },
    "press": { "frequency": 11, "damping": 0.68 },
    "cinematic": { "frequency": 4.2, "damping": 1.08 }
  },
  "typography": {
    "tabLabel": { "size": 16, "weight": "SemiBold", "figma": "type/tab/label" },
    "rowLabel": { "size": 13, "weight": "Medium", "figma": "type/row/label" },
    "sectionTitle": { "size": 14, "weight": "SemiBold", "figma": "type/section/title" },
    "windowTitle": { "size": 18, "weight": "SemiBold", "figma": "type/window/title" },
    "windowSubtitle": { "size": 13, "weight": "Medium", "figma": "type/window/subtitle" }
  },
  "v2": {
    "themes": ["ArrrelObsidian", "ArrrelSynth", "ArrrelOcean", "ArrrelEmber", "ArrrelStealth", "ArrrelPaper", "ArrrelVoid"],
    "layoutProfiles": ["cinema", "ultrawide", "minimal", "accessibility"],
    "motionProfiles": ["reduced", "snappy", "fluid", "bouncy", "cinematic"],
    "tooltipStyles": ["minimal", "card", "rich"],
    "notifyStyles": ["glass", "rail", "banner", "pill"],
    "accents": ["Crimson", "Lime", "Sky", "Gold", "Plum", "Teal", "Blaze", "Mono"]
  },
  "components": {
    "window": {
      "width": 860,
      "height": 560,
      "cornerRadius": 12,
      "stroke": { "color": "divider", "opacity": 0.9, "width": 1 },
      "ambientGlow": true
    },
    "sidebar": {
      "width": 280,
      "divider": { "width": 1, "opacity": 0.9 },
      "glassVeil": true
    },
    "tab": {
      "height": 40,
      "cornerRadius": 8,
      "activeFillOpacity": 0.1,
      "activeStrokeOpacity": 0.08,
      "auroraRail": true
    },
    "section": {
      "cornerRadius": 10,
      "fillOpacity": 0.02,
      "strokeOpacity": 0.05,
      "padding": [22, 20, 20, 18],
      "lift": true
    },
    "row": {
      "height": 38,
      "hoverTextDelta": 0.18,
      "shimmer": true
    },
    "toggle": {
      "trackWidth": 41,
      "trackHeight": 21,
      "knobSize": 15,
      "glowRing": true
    },
    "slider": {
      "trackHeight": 4,
      "thumbSize": 15,
      "fillOpacity": 0.78,
      "trackStrokeOpacity": 0.12
    },
    "notification": {
      "cornerRadius": 10,
      "maxVisible": 8,
      "railWidth": 3,
      "styles": ["glass", "rail", "banner", "pill"]
    },
    "search": {
      "placeholder": "Find a setting…",
      "maxResults": 8,
      "debounceMs": 80,
      "footer": "↑↓   Enter   Esc"
    },
    "tooltip": {
      "showDelayMs": 320,
      "maxWidth": 248,
      "styles": ["minimal", "card", "rich"]
    }
  }
}
